# Public browser variable
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Server-only Netlify Function variables. Configure these in the Netlify UI
# with Functions scope; never prefix secrets with VITE_.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
N8N_WEBHOOK_URL_NURSE=https://your-n8n-host.example/webhook/nurse-agent
N8N_WEBHOOK_TOKEN_NURSE=replace-with-a-new-rotated-token

# Future SOP chatbot placeholders
N8N_WEBHOOK_URL_SOP=
N8N_WEBHOOK_TOKEN_SOP=
